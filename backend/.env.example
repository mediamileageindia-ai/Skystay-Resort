# ============================================
# SKY STAY RESORTS — Backend Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=development
PORT=4000

# Frontend
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_postgres_password
DB_NAME=skystay

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Redis (for Bull queue + cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Razorpay (get from razorpay.com/dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Amazon SES (Email)
AWS_SES_USER=your_ses_smtp_user
AWS_SES_PASS=your_ses_smtp_password
FROM_EMAIL=noreply@skystayresorts.com

# Amazon S3 (Image Storage)
AWS_S3_BUCKET=skystay-resorts-media

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# MSG91 (SMS)
MSG91_AUTH_KEY=your_msg91_auth_key

# Admin
ADMIN_EMAIL=admin@skystayresorts.com
ADMIN_DEFAULT_PASSWORD=change_this_immediately
